{
	"schemaVersion": 1,
	"id": "clientmovement",
	"version": "${version}",
	"name": "ClientMovement",
	"description": "Makes movement (sprinting, pose changes) fully client-sided with no server intervention",
	"authors": [
		"Zorty"
	],
	"contact": {
		"sources": "https://github.com/zortler/client-movement"
	},
	"license": "MIT",
	"icon": "assets/clientmovement/icon.png",
	"environment": "client",
	"mixins": [
		"clientmovement.mixins.json",
		{
			"config": "clientmovement.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}